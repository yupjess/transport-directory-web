---
import Layout from '../layouts/Layout.astro';
import AppProvider from '../components/AppProvider';
import TransportWidget from '../components/TransportWidget';
import DirectoryWidget from '../components/DirectoryWidget';
import MapWidget from '../components/MapWidget';
---

<Layout title="Resource Hub | PH Transport & Directory">
  <!-- Navigation -->
  <nav class="bg-white border-b border-slate-200 sticky top-0 z-50">
    <div class="max-w-6xl mx-auto px-6 py-4 flex justify-between items-center">
      <div class="flex items-center gap-2 font-bold text-xl text-slate-800">
        <i class="fa-solid fa-gauge-speedometer text-blue-600"></i>
        Resource Hub
      </div>
      <div class="flex gap-2">
        <button onclick="showTab('home')" id="tab-home" class="tab-btn active-tab px-4 py-2 rounded-lg text-sm font-medium transition-all hover:bg-slate-100">Home</button>
        <button onclick="showTab('transport')" id="tab-transport" class="tab-btn px-4 py-2 rounded-lg text-sm font-medium text-slate-600 transition-all hover:bg-slate-100">Transport</button>
        <button onclick="showTab('directory')" id="tab-directory" class="tab-btn px-4 py-2 rounded-lg text-sm font-medium text-slate-600 transition-all hover:bg-slate-100">Directory</button>
        <button onclick="showTab('map')" id="tab-map" class="tab-btn px-4 py-2 rounded-lg text-sm font-medium text-slate-600 transition-all hover:bg-slate-100">Map</button>
      </div>
    </div>
  </nav>

  <main class="max-w-6xl mx-auto p-6">
    <!-- HOME TAB -->
    <div id="content-home" class="tab-content active space-y-12 py-12 text-center">
      <header class="space-y-4">
        <div class="inline-flex p-4 bg-blue-100 rounded-3xl text-blue-600 mb-4">
          <i class="fa-solid fa-layer-group text-3xl"></i>
        </div>
        <h1 class="text-5xl font-extrabold text-slate-900 tracking-tight">Unified Resource Dashboard</h1>
        <p class="text-lg text-slate-600 max-w-2xl mx-auto">
          Real-time Philippine fuel prices, LTFRB fare calculations, and the Adventist organization directory.
        </p>
      </header>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 py-8">
        <div onclick="showTab('transport')" class="cursor-pointer group p-8 bg-white rounded-3xl shadow-sm border border-slate-200 hover:border-blue-500 hover:shadow-md transition-all text-left">
          <div class="flex items-center gap-4 mb-6">
            <div class="p-3 bg-blue-50 rounded-xl text-blue-600 group-hover:bg-blue-600 group-hover:text-white transition-colors">
              <i class="fa-solid fa-gas-pump text-xl"></i>
            </div>
            <h2 class="text-2xl font-bold text-slate-800">Transport Hub</h2>
          </div>
          <p class="text-slate-600 mb-6">Check latest fuel prices and calculate commuter or vehicle trip costs.</p>
          <div class="flex items-center gap-2 text-blue-600 font-semibold">Explore Tools <i class="fa-solid fa-arrow-right text-sm"></i></div>
        </div>

        <div onclick="showTab('directory')" class="cursor-pointer group p-8 bg-white rounded-3xl shadow-sm border border-slate-200 hover:border-orange-500 hover:shadow-md transition-all text-left">
          <div class="flex items-center gap-4 mb-6">
            <div class="p-3 bg-orange-50 rounded-xl text-orange-600 group-hover:bg-orange-600 group-hover:text-white transition-colors">
              <i class="fa-solid fa-address-book text-xl"></i>
            </div>
            <h2 class="text-2xl font-bold text-slate-800">Directory Explorer</h2>
          </div>
          <p class="text-slate-600 mb-6">Browse Seventh-day Adventist church and company records.</p>
          <div class="flex items-center gap-2 text-orange-600 font-semibold">Browse Records <i class="fa-solid fa-arrow-right text-sm"></i></div>
        </div>
      </div>
    </div>

    <!-- TRANSPORT TAB -->
    <div id="content-transport" class="tab-content space-y-8">
      <h1 class="text-3xl font-bold text-slate-900 flex items-center gap-3">
        <i class="fa-solid fa-gas-pump text-blue-600"></i> PH Transport Hub
      </h1>
      <AppProvider client:only="react">
        <TransportWidget client:only="react" />
      </AppProvider>
    </div>

    <!-- DIRECTORY TAB -->
    <div id="content-directory" class="tab-content space-y-6">
      <h1 class="text-3xl font-bold text-slate-900 flex items-center gap-3">
        <i class="fa-solid fa-address-book text-orange-600"></i> Adventist Directory
      </h1>
      <AppProvider client:only="react">
        <DirectoryWidget client:only="react" />
      </AppProvider>
    </div>

    <!-- MAP TAB -->
    <div id="content-map" class="tab-content space-y-6">
      <h1 class="text-3xl font-bold text-slate-900 flex items-center gap-3">
        <i class="fa-solid fa-map text-green-600"></i> Directory Map
      </h1>
      <AppProvider client:only="react">
        <MapWidget client:only="react" />
      </AppProvider>
    </div>
  </main>
</Layout>